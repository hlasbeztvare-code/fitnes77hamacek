# Shoptet API Integration
SHOPTET_API_URL=https://api.myshoptet.com/api
SHOPTET_API_KEY=your_shoptet_api_key_here
SHOPTET_ESHOP_ID=your_eshop_id

# Shoptet OAuth (pro pokročilou integraci)
SHOPTET_CLIENT_ID=your_client_id
SHOPTET_CLIENT_SECRET=your_client_secret
SHOPTET_REDIRECT_URI=https://your-domain.com/api/shoptet/callback

# Platební brána (Shoptet Pay nebo externí)
PAYMENT_GATEWAY=shoptet_pay
# nebo
# PAYMENT_GATEWAY=stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

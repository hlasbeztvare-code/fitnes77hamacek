generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  url       = env("POSTGRES_PRISMA_URL") // Pro běžný chod (pooling)
  directUrl = env("POSTGRES_URL_NON_POOLING") // Pro migrace a seedování
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  description      String
  price            Float
  compareAtPrice   Float?
  image            String
  stock            Int      @default(0)
  category         String
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BazaarListing {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  price         Float
  originalPrice Float?
  condition     String
  location      String
  image         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Trainer {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  role        String
  bio         String
  image       String
  specialties String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  category  String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  address    String
  city       String
  zip        String
  total      Float
  itemsJson  String
  createdAt  DateTime @default(now())
}

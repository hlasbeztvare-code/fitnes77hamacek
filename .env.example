DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── Meta Graph API (FB + IG automatické příspěvky) ────────────────────────
# Jak získat: https://developers.facebook.com → App → Access Token Tool
META_FB_PAGE_ID="vaše_page_id"                     # Číselné ID FB stránky
META_FB_PAGE_ACCESS_TOKEN="váš_long_lived_token"   # Long-Lived Page Access Token
META_IG_ACCOUNT_ID="vaše_ig_business_account_id"  # IG Business Account ID (číslo)

# ─── Interní bezpečnostní klíč (libovolný náhodný string) ──────────────────
INTERNAL_API_SECRET="vygeneruj-nahodny-string-zde"

# ─── URL produkčního webu (pro generování absolutních odkazů) ──────────────
NEXT_PUBLIC_APP_URL="https://fitness77.cz"
